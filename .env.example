# CareerForge AI Environment Variables 🚀
# Copy this file to '.env' and fill in your values.

# Groq API Key (gsk_...) - Required for Resume Analyzer, Project Generator, Interview Prep, and Roadmaps.
GROQ_API_KEY=your_groq_api_key_here

# JWT Secret - A strong secret key used for signing JWT tokens for user authentication.
# You can leave the default if testing locally, or generate a random 64-character hex string.
JWT_SECRET=7d6c5b4a3928170f6e5d4c3b2a19087f6e5d4c3b2a19087f6e5d4c3b2a19087f
